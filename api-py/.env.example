# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit secrets. Never paste values into chat — assistant won't read .env.

# Neon Postgres — paste the raw connection string from neon.tech console.
# Auto-adapted at runtime to use asyncpg + correct SSL param.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Azure Document Intelligence — copy from `cd ../api && dotnet user-secrets list`
AZURE_DI_ENDPOINT=https://taia-ams-docai.cognitiveservices.azure.com/
AZURE_DI_KEY=

# Azure Blob Storage — copy from `cd ../api && dotnet user-secrets list`
AZURE_BLOB_CONNECTION_STRING=
# Container name. Match the .NET app's BlobStorage:ContainerName so both
# APIs see the same uploads during cutover (or pick any name for a fresh
# container — the service creates blobs but does not create the container).
AZURE_BLOB_CONTAINER=documents

# CORS — comma-separated origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000
